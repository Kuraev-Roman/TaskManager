<Window x:Class="TaskManager.WPF.Views.TaskEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:TaskManager.Core.Models;assembly=TaskManager.Core"
        Title="Задача" Height="560" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="#F5F6FA">
    <Border Padding="24">
        <StackPanel>
            <TextBlock Text="Название" Style="{StaticResource FormLabel}"/>
            <TextBox x:Name="TxtTitle" Style="{StaticResource FormInput}"/>
            <TextBlock Text="Описание" Style="{StaticResource FormLabel}"/>
            <TextBox x:Name="TxtDescription" Height="80" AcceptsReturn="True"
                     TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                     Style="{StaticResource FormInput}"/>
            <TextBlock Text="Приоритет" Style="{StaticResource FormLabel}"/>
            <ComboBox x:Name="CmbPriority" Padding="6,4">
                <ComboBoxItem Content="Низкий"  Tag="{x:Static models:TaskPriority.Low}"/>
                <ComboBoxItem Content="Средний" Tag="{x:Static models:TaskPriority.Medium}"/>
                <ComboBoxItem Content="Высокий" Tag="{x:Static models:TaskPriority.High}"/>
            </ComboBox>
            <TextBlock Text="Срок выполнения" Style="{StaticResource FormLabel}"/>
            <DatePicker x:Name="DpDueDate"/>
            <TextBlock Text="Статус" Style="{StaticResource FormLabel}"/>
            <ComboBox x:Name="CmbStatus" Padding="6,4">
                <ComboBoxItem Content="Новая"      Tag="{x:Static models:TaskStatus.New}"/>
                <ComboBoxItem Content="В процессе" Tag="{x:Static models:TaskStatus.InProgress}"/>
                <ComboBoxItem Content="Завершена"  Tag="{x:Static models:TaskStatus.Completed}"/>
            </ComboBox>
            <CheckBox x:Name="ChkImportant" Content="⭐ Важная задача"
                      Margin="0,16,0,0" FontSize="13"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Отмена" Width="90" Padding="0,7" Margin="0,0,10,0"
                        Background="#9E9E9E" Style="{StaticResource ToolbarButton}"
                        Click="Cancel_Click"/>
                <Button Content="Сохранить" Width="100" Padding="0,7"
                        Background="{StaticResource GreenBrush}"
                        Style="{StaticResource ToolbarButton}"
                        Click="Save_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>