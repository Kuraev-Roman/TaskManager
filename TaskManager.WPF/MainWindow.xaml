<Window x:Class="TaskManager.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Task Manager" Height="750" Width="1200"
        Background="#F5F6FA">

    <DockPanel>

        <Border DockPanel.Dock="Top" Background="{StaticResource PrimaryBrush}" Padding="16,12">
            <DockPanel>
                <TextBlock Text="Task Manager" Foreground="White"
                           FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <Button Content="Сохранить" Background="{StaticResource GreenBrush}"
                            Click="Save_Click" Style="{StaticResource ToolbarButton}"/>
                    <Button Content="Загрузить" Background="{StaticResource OrangeBrush}"
                            Click="Load_Click" Style="{StaticResource ToolbarButton}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                    <Button Content="Добавить" Background="{StaticResource GreenBrush}"
                            Click="Add_Click" Style="{StaticResource ToolbarButton}"/>
                    <Button Content="Изменить" Background="{StaticResource BlueBrush}"
                            Click="Edit_Click" Style="{StaticResource ToolbarButton}"/>
                    <Button Content="Удалить" Background="{StaticResource RedBrush}"
                            Click="Delete_Click" Style="{StaticResource ToolbarButton}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#E8EAF6" Padding="16,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="StatsTotal"      Margin="0,0,28,0" FontSize="16" Text="Всего: 0"/>
                <TextBlock x:Name="StatsNew"        Margin="0,0,28,0" FontSize="16" Text="Новых: 0"/>
                <TextBlock x:Name="StatsInProgress" Margin="0,0,28,0" FontSize="16" Text="В работе: 0"/>
                <TextBlock x:Name="StatsCompleted"  Margin="0,0,28,0" FontSize="16"
                           FontWeight="Bold" Foreground="Green" Text="Завершено: 0"/>
                <TextBlock x:Name="StatsOverdue"    Margin="0,0,28,0" FontSize="16"
                           FontWeight="Bold" Foreground="#F44336" Text="Просрочено: 0"/>
                <TextBlock x:Name="StatsImportant"  FontSize="16"
                           FontWeight="Bold" Foreground="#FF9800" Text="Важных: 0"/>
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Top" Background="White" Padding="14,10"
                BorderBrush="#DDD" BorderThickness="0,0,0,1">
            <WrapPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,20,0" VerticalAlignment="Center">
                    <TextBox x:Name="SearchBox" Width="240" Padding="8,5" FontSize="14"
                             BorderBrush="#BDBDBD" VerticalAlignment="Center"
                             TextChanged="SearchBox_TextChanged"/>
                    <Button Content="X" Margin="5,0,0,0" Padding="7,4"
                            Click="ClearSearch_Click"
                            Background="Transparent" BorderBrush="#CCC" Cursor="Hand"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,20,0" VerticalAlignment="Center">
                    <TextBlock Text="Статус:" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="StatusFilter" Width="150" Padding="6,4" FontSize="14"
                              SelectionChanged="Filter_Changed">
                        <ComboBoxItem Content="Все" IsSelected="True"/>
                        <ComboBoxItem Content="Новая"/>
                        <ComboBoxItem Content="В процессе"/>
                        <ComboBoxItem Content="Завершена"/>
                    </ComboBox>
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Сортировка:" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="SortCombo" Width="180" Padding="6,4" FontSize="14"
                              SelectionChanged="Filter_Changed">
                        <ComboBoxItem Content="По умолчанию" IsSelected="True"/>
                        <ComboBoxItem Content="Приоритет ↓"/>
                        <ComboBoxItem Content="Приоритет ↑"/>
                        <ComboBoxItem Content="Срок ↑"/>
                        <ComboBoxItem Content="Срок ↓"/>
                    </ComboBox>
                </StackPanel>
            </WrapPanel>
        </Border>

        <ListView x:Name="TasksList"
                  BorderThickness="0" Background="Transparent" Margin="14">

            <ListView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Добавить задачу" Click="Add_Click"/>
                    <MenuItem Header="Редактировать"   Click="Edit_Click"/>
                    <MenuItem Header="Удалить"         Click="Delete_Click"/>
                </ContextMenu>
            </ListView.ContextMenu>

            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Margin" Value="0,2"/>
                    <Setter Property="Padding" Value="4,8"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#C5CAE9"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.View>
                <GridView>
                    <GridViewColumn Header="★" Width="36">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ImportantText}"
                                           Foreground="#FF9800" FontSize="18" HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Название" Width="240">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14"
                                           TextTrimming="CharacterEllipsis"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Описание" Width="280">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Description}" FontSize="13"
                                           TextTrimming="CharacterEllipsis" Foreground="#555"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Приоритет" Width="110">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding PriorityText}" FontSize="13"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Срок" Width="110">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DueDate, StringFormat='dd.MM.yyyy'}" FontSize="14"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Статус" Width="120">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding StatusText}" FontSize="14"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Создана" Width="140">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding CreatedAt, StringFormat='dd.MM.yyyy HH:mm'}"
                                           Foreground="#888" FontSize="12"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>
    </DockPanel>
</Window>