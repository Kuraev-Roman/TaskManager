<Window x:Class="TaskManager.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:TaskManager.WPF.Controls.Helpers"
        Title="Task Manager" Height="750" Width="1200"
        Background="#F5F6FA">

    <Window.Resources>
        <conv:StatusToColorConverter     x:Key="StatusColor"/>
        <conv:BoolToStarConverter        x:Key="BoolToStar"/>
        <conv:OverdueToBrushConverter    x:Key="OverdueBrush"/>
        <conv:PriorityToColorConverter   x:Key="PriorityColor"/>
        <conv:StatusToRussianConverter   x:Key="StatusRus"/>
        <conv:PriorityToRussianConverter x:Key="PriorityRus"/>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{StaticResource PrimaryBrush}" Padding="16,12">
            <DockPanel>
                <TextBlock Text="Task Manager" Foreground="White"
                           FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <Button Content="Сохранить" Background="{StaticResource GreenBrush}"
                            Command="{Binding SaveCommand}" Style="{StaticResource ToolbarButton}"/>
                    <Button Content="Загрузить" Background="{StaticResource OrangeBrush}"
                            Command="{Binding LoadCommand}" Style="{StaticResource ToolbarButton}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                    <Button Content="Добавить" Background="{StaticResource GreenBrush}"
                            Command="{Binding AddCommand}" Style="{StaticResource ToolbarButton}"/>
                    <Button Content="Изменить" Background="{StaticResource BlueBrush}"
                            Command="{Binding EditCommand}" Style="{StaticResource ToolbarButton}"/>
                    <Button Content="Удалить" Background="{StaticResource RedBrush}"
                            Command="{Binding DeleteCommand}" Style="{StaticResource ToolbarButton}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#E8EAF6" Padding="16,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Margin="0,0,28,0" FontSize="16"
                           Text="{Binding Stats.Total,      StringFormat='Всего: {0}'}"/>
                <TextBlock Margin="0,0,28,0" FontSize="16"
                           Text="{Binding Stats.New,        StringFormat='Новых: {0}'}"/>
                <TextBlock Margin="0,0,28,0" FontSize="16"
                           Text="{Binding Stats.InProgress, StringFormat='В работе: {0}'}"/>
                <TextBlock Margin="0,0,28,0" FontSize="16"
                           Text="{Binding Stats.Completed,  StringFormat='Завершено: {0}'}"/>
                <TextBlock Margin="0,0,28,0" FontSize="16" FontWeight="Bold" Foreground="#F44336"
                           Text="{Binding Stats.Overdue,    StringFormat='Просрочено: {0}'}"/>
                <TextBlock FontSize="16" FontWeight="Bold" Foreground="#FF9800"
                           Text="{Binding Stats.Important,  StringFormat='Важных: {0}'}"/>
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Top" Background="White" Padding="14,10"
                BorderBrush="#DDD" BorderThickness="0,0,0,1">
            <WrapPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,20,0" VerticalAlignment="Center">
                    <TextBox Width="240" Padding="8,5" FontSize="14" BorderBrush="#BDBDBD"
                             Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             VerticalAlignment="Center"/>
                    <Button Content="X" Margin="5,0,0,0" Padding="7,4"
                            Command="{Binding ClearSearchCommand}"
                            Background="Transparent" BorderBrush="#CCC" Cursor="Hand"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,20,0" VerticalAlignment="Center">
                    <TextBlock Text="Статус:" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox Width="150" Padding="6,4" FontSize="14"
                              ItemsSource="{Binding StatusFilters}"
                              SelectedItem="{Binding StatusFilter}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Сортировка:" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox Width="180" Padding="6,4" FontSize="14"
                              ItemsSource="{Binding SortModes}"
                              SelectedItem="{Binding SortMode}"/>
                </StackPanel>
            </WrapPanel>
        </Border>

        <ListView ItemsSource="{Binding Tasks}"
                  SelectedItem="{Binding SelectedTask}"
                  BorderThickness="0" Background="Transparent" Margin="14">

    
            <ListView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Добавить задачу" Command="{Binding AddCommand}"/>
                    <MenuItem Header="Редактировать" Command="{Binding EditCommand}"/>
                    <MenuItem Header="Удалить" Command="{Binding DeleteCommand}"/>
                </ContextMenu>
            </ListView.ContextMenu>

            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Background"
                            Value="{Binding Status, Converter={StaticResource StatusColor}}"/>
                    <Setter Property="Margin" Value="0,2"/>
                    <Setter Property="Padding" Value="4,8"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#C5CAE9"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.View>
                <GridView>
                    <GridViewColumn Width="36">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding IsImportant, Converter={StaticResource BoolToStar}}"
                                           Foreground="#FF9800" FontSize="18" HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Название" Width="240">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14"
                                           Foreground="{Binding IsOverdue, Converter={StaticResource OverdueBrush}}"
                                           TextTrimming="CharacterEllipsis"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Описание" Width="280">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Description}" FontSize="13"
                                           TextTrimming="CharacterEllipsis" Foreground="#555"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Приоритет" Width="110">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="4" Padding="8,3"
                                        Background="{Binding Priority, Converter={StaticResource PriorityColor}}">
                                    <TextBlock Text="{Binding Priority, Converter={StaticResource PriorityRus}}"
                                               Foreground="White" FontSize="12" FontWeight="SemiBold"
                                               HorizontalAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Срок" Width="110">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DueDate, StringFormat='dd.MM.yyyy'}" FontSize="14"
                                           Foreground="{Binding IsOverdue, Converter={StaticResource OverdueBrush}}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Статус" Width="120">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Status, Converter={StaticResource StatusRus}}" FontSize="14"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Создана" Width="140">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding CreatedAt, StringFormat='dd.MM.yyyy HH:mm'}"
                                           Foreground="#888" FontSize="12"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>
    </DockPanel>
</Window>